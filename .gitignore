__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# Node
node_modules/
.next/
.turbo/

# Project data (athlete data — never commit)
data/raw/
data/processed/
data/photos/
*.db
*.sqlite
*.sqlite3

# Per-user dev tooling — not portable across users
.claude/launch.json

# Trained models (too large for git; tracked via models/registry.json)
models/**/weights.pt
models/**/*.bin
models/**/*.task

# Environment
.env
.env.local

# OS / IDE
.DS_Store
.idea/
.vscode/

# Keep directory markers
!data/.gitkeep
!models/.gitkeep
!notebooks/.gitkeep
!data/fixtures/
~$*.docx
~$*.doc

# Generated ML artifacts — built by scripts/ml/, not source.
data/ml/datasets/
data/ml/raw/
data/ml/punch_lstm_v1.pkl
Datasets/

# Start/stop script runtime files
.backend.log
.frontend.log
.alion.pids
