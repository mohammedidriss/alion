# Copy to .env and fill in. .env is gitignored.

# Database
ALION_DB_PATH=./data/alion.db

# Logging
ALION_LOG_LEVEL=INFO

# LLM (Phase 5+)
ALION_LM_STUDIO_URL=http://localhost:1234/v1
ALION_LLM_MODEL=llama-3.1-8b-instruct
# Fallback only — for prompt-engineering experiments. Never used with athlete data.
ANTHROPIC_API_KEY=
