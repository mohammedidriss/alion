# Copy to .env and fill in. .env is gitignored.

# Database
COMBAT_INTEL_DB_PATH=./data/combat_intel.db

# Logging
COMBAT_INTEL_LOG_LEVEL=INFO

# LLM (Phase 5+)
COMBAT_INTEL_LM_STUDIO_URL=http://localhost:1234/v1
COMBAT_INTEL_LLM_MODEL=llama-3.1-8b-instruct
# Fallback only — for prompt-engineering experiments. Never used with athlete data.
ANTHROPIC_API_KEY=
