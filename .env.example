# Copy to .env and fill in values. .env is gitignored.
# All variables work identically on Railway, AWS, Azure, GCP, Oracle, or any VPS.

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, local dev only):
ALION_DB_PATH=./data/alion.db

# PostgreSQL (production — set this and SQLite is ignored automatically):
# ALION_DATABASE_URL=postgresql+psycopg://user:password@host:5432/alion

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Server will warn loudly on startup if this is not set.
ALION_JWT_SECRET=change-me-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed frontend origins.
# Defaults to localhost when unset (dev only).
# Production: ALION_CORS_ORIGINS=https://app.yourdomain.com,https://yourdomain.com
ALION_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── API server ────────────────────────────────────────────────────────────────
ALION_LOG_LEVEL=INFO

# ── Dashboard (Next.js — set at build time) ───────────────────────────────────
# URL of the deployed API server.
# Works with any cloud provider — just point at your server.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Mobile app (Capacitor — set at build time) ────────────────────────────────
# URL of the deployed dashboard loaded by the iOS/Android WebView.
# Works with any host: Vercel, AWS CloudFront, Azure Static Web Apps, Nginx, etc.
CAPACITOR_PROD_URL=https://app.yourdomain.com

# ── LLM / AI (optional) ───────────────────────────────────────────────────────
ALION_LM_STUDIO_URL=http://localhost:1234/v1
ALION_LLM_MODEL=llama-3.1-8b-instruct
ANTHROPIC_API_KEY=
